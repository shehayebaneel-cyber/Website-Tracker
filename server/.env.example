# Copy to .env and fill in. Never commit .env.
# App (runtime) connection. Locally this is the portable Postgres on :5433.
# On Neon use the POOLED endpoint (host contains "-pooler") + ?sslmode=require&pgbouncer=true
DATABASE_URL="postgresql://tracker:tracker@localhost:5433/website_tracker?schema=public"
# Direct (non-pooled) connection used ONLY for Prisma migrations. Locally it can
# equal DATABASE_URL; on Neon use the endpoint WITHOUT "-pooler" + ?sslmode=require
DIRECT_URL="postgresql://tracker:tracker@localhost:5433/website_tracker?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=4020
NODE_ENV=development
CORS_ORIGIN="http://localhost:5180"
# First-run admin bootstrap (used by seed only if no users exist)
ADMIN_EMAIL="shehayebaneel@gmail.com"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Aneel"
