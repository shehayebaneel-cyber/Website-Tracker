// Website Tracker & Client Management — data model
// Design rule: derived values (balances, statuses, days-remaining, collection
// rate, paid-through) are NEVER stored. They are computed in src/lib/calc.ts so
// the numbers can never drift the way the spreadsheet's broken formulas did.
// Only immutable facts are stored (an invoice snapshots its own amount at
// creation, so later monthly-fee changes never rewrite billing history).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (PgBouncer) for the app at runtime.
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection for migrations. Falls back to DATABASE_URL
  // locally where there is no separate pooler. On Neon, set this to the
  // endpoint WITHOUT "-pooler".
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Users & auth
// ---------------------------------------------------------------------------
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("OWNER") // OWNER | STAFF | DEVELOPER | MANAGER | SALESPERSON | CLIENT
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  activity    ActivityLog[]
  salesperson Salesperson?
  client      Client?
}

// ---------------------------------------------------------------------------
// Configurable dropdown option lists (Settings page manages these)
// ---------------------------------------------------------------------------
model OptionList {
  id      String  @id @default(cuid())
  listKey String // e.g. "clientStatus", "servicePlan", "expenseCategory"
  value   String
  order   Int     @default(0)
  active  Boolean @default(true)

  @@unique([listKey, value])
  @@index([listKey])
}

// Scalar / structured settings: currency, reminder windows, company info, billing rules
model Config {
  id    String @id @default(cuid())
  key   String @unique
  value String // JSON-encoded when structured
}

// ---------------------------------------------------------------------------
// Clients
// ---------------------------------------------------------------------------
model Client {
  id                    String    @id @default(cuid())
  code                  String    @unique // C001
  userId                String?   @unique // linked portal login (role CLIENT)
  businessName          String
  contactName           String?
  phone                 String?
  website               String?
  city                  String?
  subscriptionStartDate DateTime?
  billingDay            Int? // day-of-month the subscription is due (1-31)
  monthlyFee            Decimal   @default(0) @db.Decimal(12, 2)
  servicePlan           String? // Basic | Standard | Premium | Custom
  status                String    @default("Active") // Active | Trial | Paused | Cancelled
  pauseDate             DateTime?
  cancellationDate      DateTime?
  paymentMethod         String?
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime? // soft delete / archive

  portalUser        User?              @relation(fields: [userId], references: [id])
  websites          Website[]
  invoices          Invoice[]
  payments          Payment[]
  expenses          Expense[]
  tickets           SupportTicket[]
  assignments       ClientAssignment[]
  commissions       Commission[]
  followUps         MonthlyFollowUp[]
  convertedFromLead Lead?

  @@index([status])
  @@index([deletedAt])
}

// ---------------------------------------------------------------------------
// Websites
// ---------------------------------------------------------------------------
model Website {
  id               String    @id @default(cuid())
  code             String    @unique // WEB-C001-01
  clientId         String
  projectName      String?
  primaryUrl       String?
  status           String    @default("Planning") // Planning | In Development | Live | Paused | Cancelled
  projectStartDate DateTime?
  launchDate       DateTime?
  notes            String?

  // Subscription (per-website billing). Each active website carries its own
  // monthly subscription; one subscription invoice is generated per website per
  // billing month, and one $5 commission is earned when that invoice is paid.
  monthlyFee              Decimal   @default(0) @db.Decimal(12, 2)
  billingDay              Int       @default(1) // day-of-month the subscription is due (1-31)
  subscriptionStartDate   DateTime?
  subscriptionActive      Boolean   @default(true)
  includedUpdatesPerMonth Int       @default(3) // small updates included in the subscription each month

  // Domain
  domainName         String?
  domainProvider     String?
  domainOwner        String? // Me | Client | Shared
  domainCost         Decimal?  @db.Decimal(12, 2)
  domainPurchaseDate DateTime?
  domainRenewalDate  DateTime?
  domainAutoRenew    Boolean   @default(false)

  // Hosting
  hostingProvider    String?
  hostingOwner       String?
  hostingPlan        String?
  hostingCost        Decimal?  @db.Decimal(12, 2)
  hostingRenewalDate DateTime?
  hostingAutoRenew   Boolean   @default(false)

  // SSL
  sslExpiryDate DateTime?

  // Technical
  repositoryUrl          String?
  deploymentPlatform     String?
  adminUrl               String?
  analyticsInstalled     Boolean   @default(false)
  searchConsoleInstalled Boolean   @default(false)
  lastBackupDate         DateTime?
  lastWebsiteUpdate      DateTime?
  credentialLocation     String? // password-manager reference only — never a raw password
  techNotes              String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  client      Client             @relation(fields: [clientId], references: [id])
  expenses    Expense[]
  tickets     SupportTicket[]
  assignments ClientAssignment[]
  invoices    Invoice[]
  commissions Commission[]

  @@index([clientId])
  @@index([status])
  @@index([deletedAt])
}

// ---------------------------------------------------------------------------
// Invoices  (an invoice snapshots its own amount — history never rewrites)
// ---------------------------------------------------------------------------
model Invoice {
  id               String    @id @default(cuid())
  code             String    @unique // INV-202607-C001-01
  clientId         String
  websiteId        String? // subscription invoices belong to a website; other charges may be client-level
  invoiceDate      DateTime
  billingMonth     DateTime // first day of the billing month
  chargeType       String    @default("Monthly Subscription")
  description      String?
  dueDate          DateTime // resolved at creation (manual, or from client.billingDay)
  amount           Decimal   @default(0) @db.Decimal(12, 2) // charge before discount (subscription = monthlyFee snapshot)
  discount         Decimal   @default(0) @db.Decimal(12, 2)
  reminderStatus   String    @default("Not Sent")
  lastReminderDate DateTime?
  notes            String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  client   Client          @relation(fields: [clientId], references: [id])
  website  Website?        @relation(fields: [websiteId], references: [id])
  payments Payment[]
  tickets  SupportTicket[]

  @@index([clientId])
  @@index([websiteId])
  @@index([billingMonth])
  @@index([chargeType])
  @@index([deletedAt])
}

// ---------------------------------------------------------------------------
// Payments
// ---------------------------------------------------------------------------
model Payment {
  id            String    @id @default(cuid())
  code          String    @unique // PAY-20260720-001
  paymentDate   DateTime
  invoiceId     String?
  clientId      String
  amount        Decimal   @db.Decimal(12, 2)
  method        String    @default("Cash") // Cash | Whish | Bank Transfer | Card | Other
  reference     String?
  receivedBy    String?
  depositStatus String    @default("Not Deposited") // Not Deposited | Deposited | Not Applicable
  depositDate   DateTime?
  notes         String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  invoice Invoice? @relation(fields: [invoiceId], references: [id])
  client  Client   @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([invoiceId])
  @@index([paymentDate])
  @@index([deletedAt])
}

// ---------------------------------------------------------------------------
// Expenses
// ---------------------------------------------------------------------------
model Expense {
  id                  String    @id @default(cuid())
  code                String    @unique // EXP-202607-001
  expenseDate         DateTime
  expenseMonth        DateTime // first day of month
  vendor              String?
  category            String    @default("Other")
  clientId            String?
  websiteId           String?
  description         String?
  amount              Decimal   @db.Decimal(12, 2)
  method              String?
  recurring           Boolean   @default(false)
  renewalFrequency    String? // Monthly | Quarterly | Every 6 Months | Yearly | One Time
  nextRenewalDate     DateTime?
  reimbursable        Boolean   @default(false)
  reimbursementStatus String    @default("Not Applicable")
  receiptUrl          String?
  notes               String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  client  Client?  @relation(fields: [clientId], references: [id])
  website Website? @relation(fields: [websiteId], references: [id])

  @@index([clientId])
  @@index([websiteId])
  @@index([expenseMonth])
  @@index([category])
  @@index([deletedAt])
}

// ---------------------------------------------------------------------------
// Support / work tickets
// ---------------------------------------------------------------------------
model SupportTicket {
  id                     String    @id @default(cuid())
  code                   String    @unique // TKT-202607-001 (internal) or SUP-202607-001 (from website)
  requestedDate          DateTime
  requestSource          String?
  clientId               String? // nullable: a website request may not match a client yet
  websiteId              String?
  category               String    @default("Other")
  summary                String
  priority               String    @default("Medium") // Low | Medium | High | Urgent
  status                 String    @default("Not Started")
  assignedTo             String?
  dueDate                DateTime?
  completedDate          DateTime?
  hoursSpent             Decimal   @default(0) @db.Decimal(8, 2)
  includedInSubscription Boolean   @default(true)
  extraCharge            Decimal   @default(0) @db.Decimal(12, 2)
  clientApproved         Boolean   @default(false)
  invoiceId              String?
  requestLink            String?
  notes                  String?

  // public "Client Support" intake (from the website)
  requestType       String? // detailed customer-facing type (Website Not Opening, Update Price, ...)
  requesterName     String?
  requesterEmail    String?
  requesterPhone    String?
  requesterBusiness String?
  requesterWebsite  String?
  pageUrl           String?
  deviceInfo        String?
  browserInfo       String?
  problemStarted    String?
  frequency         String?
  stepsToReproduce  String?
  businessImpact    String?
  files             Json?

  // client confirmation that a completed request is actually resolved
  clientConfirmed   Boolean   @default(false)
  clientConfirmedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  client   Client?         @relation(fields: [clientId], references: [id])
  website  Website?        @relation(fields: [websiteId], references: [id])
  invoice  Invoice?        @relation(fields: [invoiceId], references: [id])
  messages TicketMessage[]

  @@index([clientId])
  @@index([websiteId])
  @@index([status])
  @@index([priority])
  @@index([deletedAt])
}

// A message in a support-ticket conversation (client <-> IGNIS team).
model TicketMessage {
  id          String   @id @default(cuid())
  ticketId    String
  sender      String // "client" | "team"
  authorName  String?
  body        String
  attachments Json?
  createdAt   DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
}

// ---------------------------------------------------------------------------
// Activity log & notifications
// ---------------------------------------------------------------------------
model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  entityType String // "Client" | "Invoice" | ...
  entityId   String?
  action     String // "create" | "update" | "delete" | "payment" | ...
  summary    String
  meta       Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id          String    @id @default(cuid())
  type        String // invoiceOverdue | domainRenewal | sslExpiry | ...
  severity    String    @default("info") // info | warn | attention | critical
  entityType  String?
  entityId    String?
  userId      String? // target a specific user (e.g. a salesperson)
  message     String
  dueDate     DateTime?
  read        Boolean   @default(false)
  dismissedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([read])
  @@index([type])
  @@index([userId])
}

// ===========================================================================
// SALES MODULE — commission-only sales team
// ===========================================================================

model Salesperson {
  id                           String    @id @default(cuid())
  code                         String    @unique // SP001
  userId                       String?   @unique // linked login account (role SALESPERSON)
  fullName                     String
  photoUrl                     String?
  phone                        String?
  email                        String?
  city                         String? // city or territory
  startDate                    DateTime?
  endDate                      DateTime? // final working date
  status                       String    @default("Applicant") // Applicant|Active|Paused|Inactive|Left Company|Terminated
  commissionMethod             String    @default("Fixed") // Fixed | Percentage (default plan)
  commissionAmount             Decimal   @default(5) @db.Decimal(12, 2) // fixed $ per paid website / month
  commissionPercent            Decimal   @default(25) @db.Decimal(5, 2) // % of collected subscription
  paymentMethod                String? // Whish | Bank Transfer | Cash | ...
  whishNumber                  String?
  bankInfo                     String?
  agreementUrl                 String? // reference/link only (file storage later)
  agreementSignedDate          DateTime?
  finalEligibleCommissionMonth DateTime?
  departureReason              String?
  notes                        String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user                User?              @relation(fields: [userId], references: [id])
  leads               Lead[]
  assignmentsOriginal ClientAssignment[] @relation("OriginalSalesperson")
  assignmentsCurrent  ClientAssignment[] @relation("CurrentSalesperson")
  applications        Application[]
  commissions         Commission[]
  followUps           MonthlyFollowUp[]
  payouts             Payout[]

  @@index([status])
  @@index([deletedAt])
}

model Lead {
  id                String    @id @default(cuid())
  code              String    @unique // LEAD-202607-001
  salespersonId     String
  businessName      String
  contactPerson     String?
  phone             String?
  whatsapp          String?
  email             String?
  instagram         String?
  category          String?
  city              String?
  existingWebsite   String?
  source            String? // Door-to-door | Instagram | WhatsApp | ...
  dateAdded         DateTime  @default(now())
  lastContactDate   DateTime?
  nextFollowUpDate  DateTime?
  interestedService String?
  proposedMonthly   Decimal?  @db.Decimal(12, 2)
  proposedSetup     Decimal?  @db.Decimal(12, 2)
  status            String    @default("New") // New|Contacted|Interested|...|Won|Lost|...
  closeChance       Int? // estimated % chance of closing
  lostReason        String?
  notes             String?
  convertedClientId String?   @unique // set when converted to a client

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  salesperson     Salesperson    @relation(fields: [salespersonId], references: [id])
  convertedClient Client?        @relation(fields: [convertedClientId], references: [id])
  activities      LeadActivity[]
  application     Application?

  @@index([salespersonId])
  @@index([status])
  @@index([deletedAt])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  type      String // note | call | status_change | followup | convert | transfer
  summary   String
  meta      Json?
  createdBy String?
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([leadId])
}

model ClientAssignment {
  id                    String    @id @default(cuid())
  code                  String    @unique // ASG-...
  clientId              String
  websiteId             String?
  originalSalespersonId String
  currentSalespersonId  String
  startDate             DateTime  @default(now())
  endDate               DateTime?
  effectiveBillingMonth DateTime // first day of the month commission starts
  status                String    @default("Active") // Active | Pending | Transferred | Ended
  transferReason        String?
  assignedBy            String?
  notes                 String?

  // commission agreed for this client (overrides the salesperson's default plan)
  commissionMethod  String? // Fixed | Percentage
  commissionAmount  Decimal? @db.Decimal(12, 2)
  commissionPercent Decimal? @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client              Client       @relation(fields: [clientId], references: [id])
  website             Website?     @relation(fields: [websiteId], references: [id])
  originalSalesperson Salesperson  @relation("OriginalSalesperson", fields: [originalSalespersonId], references: [id])
  currentSalesperson  Salesperson  @relation("CurrentSalesperson", fields: [currentSalespersonId], references: [id])
  commissions         Commission[]

  @@index([clientId])
  @@index([currentSalespersonId])
  @@index([status])
}

// A monthly commission the salesperson earns for ONE website when its
// subscription is paid. One row per (website, billingMonth). Derived amounts
// are recomputed by the monthly "Generate & review" run until an owner
// approves/pays them; Approved/Included in Payout/Paid rows are never downgraded.
model Commission {
  id                    String    @id @default(cuid())
  code                  String    @unique // CMM-202607-001
  websiteId             String
  clientId              String
  salespersonId         String // credited salesperson (current manager at generation)
  assignmentId          String?
  billingMonth          DateTime // first day of the month
  subscriptionInvoiceId String? // the website's subscription invoice for that month
  basis                 String    @default("Collected") // Collected | Billed
  method                String    @default("Fixed") // Fixed | Percentage
  subscriptionAmount    Decimal   @default(0) @db.Decimal(12, 2) // the $20 billed/collected
  amount                Decimal   @default(0) @db.Decimal(12, 2) // the $5 commission
  status                String    @default("Expected") // commissionStatus option list
  statusReason          String?
  followUpId            String? // the MonthlyFollowUp that satisfied eligibility (S2)
  approvedAt            DateTime?
  approvedBy            String?
  heldReason            String?
  payoutId              String? // set when included in a payout (S3)
  adjustment            Decimal   @default(0) @db.Decimal(12, 2)
  adjustmentNote        String?
  reversedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  website     Website           @relation(fields: [websiteId], references: [id])
  client      Client            @relation(fields: [clientId], references: [id])
  salesperson Salesperson       @relation(fields: [salespersonId], references: [id])
  assignment  ClientAssignment? @relation(fields: [assignmentId], references: [id])
  payout      Payout?           @relation(fields: [payoutId], references: [id])

  @@unique([websiteId, billingMonth])
  @@index([salespersonId, billingMonth])
  @@index([status])
  @@index([clientId])
  @@index([payoutId])
}

// A salesperson's monthly check-in with an assigned client. Its existence for a
// (client, month) is what moves that month's commissions from Under Review to
// Eligible. Captures satisfaction, needs, risks and upsell opportunities.
model MonthlyFollowUp {
  id                String    @id @default(cuid())
  clientId          String
  salespersonId     String
  month             DateTime // first day of the month
  contactedDate     DateTime?
  method            String? // WhatsApp | Phone | Email | In Person | Video Call | Other
  satisfaction      String? // Very Satisfied | Satisfied | Neutral | Unsatisfied | At Risk | No Response
  needsUpdate       Boolean   @default(false)
  hasTechnicalIssue Boolean   @default(false)
  mayCancel         Boolean   @default(false)
  upsellOpportunity Boolean   @default(false)
  upsellNote        String?
  notes             String?
  status            String    @default("Completed") // followUpStatus option list
  createdBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  client      Client      @relation(fields: [clientId], references: [id])
  salesperson Salesperson @relation(fields: [salespersonId], references: [id])

  @@unique([clientId, month])
  @@index([salespersonId, month])
  @@index([clientId])
}

// A monthly payment to a salesperson bundling their Approved commissions.
// A statement is rendered from the linked commission rows.
model Payout {
  id               String    @id @default(cuid())
  code             String    @unique // PO-202607-001
  salespersonId    String
  periodMonth      DateTime // the month the payout is issued for
  status           String    @default("Draft") // payoutStatus option list
  totalEarned      Decimal   @default(0) @db.Decimal(12, 2)
  totalHeld        Decimal   @default(0) @db.Decimal(12, 2)
  totalAdjustments Decimal   @default(0) @db.Decimal(12, 2)
  netAmount        Decimal   @default(0) @db.Decimal(12, 2)
  paidDate         DateTime?
  method           String?
  reference        String?
  proofUrl         String? // reference/link only
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  salesperson Salesperson  @relation(fields: [salespersonId], references: [id])
  commissions Commission[]

  @@index([salespersonId])
  @@index([status])
}

// Public "Start Your Website" application. Creates a CRM lead on submit; the
// richer intake (needs, content, files, consent) lives here linked to that lead.
model Application {
  id     String @id @default(cuid())
  code   String @unique // APP-202607-001
  status String @default("Application Received") // customer-friendly statuses (§20)

  // Step 1 — about the business
  businessName    String
  category        String?
  contactPerson   String?
  phone           String?
  whatsapp        String?
  email           String?
  city            String?
  country         String?
  instagram       String?
  existingWebsite String?
  isOperating     Boolean @default(true)
  description     String?

  // Step 2 — what they need
  needType      String? // new | redesign
  plan          String? // basic | standard | premium
  needs         Json? // { bookings, ordering, store, customerAccounts, ... }
  otherFeatures String?

  // Step 3 — content they have + uploaded files
  hasContent Json? // { logo, description, serviceList, prices, photos, ... }
  files      Json? // [{ name, url, size, type }]

  // Step 4 — timeline & contact
  launchTimeline String?
  contactMethod  String?
  bestTime       String?
  meetingType    String?
  additionalInfo String?
  hearAbout      String?
  referralCode   String?

  // consent (§7 step 5)
  consentContact Boolean @default(false)
  priceMayChange Boolean @default(false)
  privacyAgreed  Boolean @default(false)

  // sales / marketing connection (§17)
  salespersonId   String?
  leadId          String? @unique
  marketingSource String?
  campaign        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archived  Boolean  @default(false)

  salesperson Salesperson? @relation(fields: [salespersonId], references: [id])
  lead        Lead?        @relation(fields: [leadId], references: [id])

  @@index([status])
  @@index([salespersonId])
}

// ---------------------------------------------------------------------------
// Pricing model (public site: Plans, Business Features & Add-ons, Plan Builder)
//
// Design rule: this is the SINGLE source of truth for every pricing surface.
// Plan cards, the comparison table, the feature catalogue, the Plan Builder,
// the WhatsApp message and the final summary all render from these tables, so
// they can never contradict each other. Nothing here is hardcoded in the web
// apps. Totals are always DERIVED by src/lib/pricing.ts - never stored on a
// configuration except as an immutable snapshot of what the customer was shown.
// ---------------------------------------------------------------------------

// The one base website every customer starts from. A single active row.
model BaseWebsite {
  id          String @id @default(cuid())
  key         String @unique @default("base")
  name        String // "Base Informational Website"
  heading     String // "Start with your business website"
  description String
  ctaLabel    String @default("Start with Informational")

  price            Decimal @default(10) @db.Decimal(12, 2)
  priceNote        String  @default("/month")
  includedSections Int     @default(6)
  monthlyUpdates   Int     @default(1)

  active Boolean @default(true)

  inclusions BaseInclusion[]
}

model BaseInclusion {
  id     String  @id @default(cuid())
  baseId String
  label  String
  order  Int     @default(0)
  active Boolean @default(true)

  base BaseWebsite @relation(fields: [baseId], references: [id], onDelete: Cascade)

  @@index([baseId, order])
}

// A core system the customer adds ON TOP of the base website. Booking and
// E-commerce are each priced in their own right, so choosing both costs exactly
// the sum of the two - there is no combined price to keep in step.
model CoreSystem {
  id          String @id @default(cuid())
  key         String @unique // booking | store
  name        String // "Booking System"
  shortName   String // "Booking"
  heading     String // "Take bookings online"
  description String
  ctaLabel    String @default("Add this system")

  price Decimal @default(10) @db.Decimal(12, 2)
  icon  String?

  order  Int     @default(0)
  active Boolean @default(true)

  inclusions SystemInclusion[]
  limits     SystemLimit[]
}

// What a core system includes. These are the essentials that must never be
// stripped out and sold back as a pack.
model SystemInclusion {
  id       String  @id @default(cuid())
  systemId String
  label    String
  group    String? // optional sub-heading, e.g. "Order management"
  order    Int     @default(0)
  active   Boolean @default(true)

  system CoreSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@index([systemId, order])
}

// A countable allowance of a core system. `upgradedValue` is what the limit
// becomes when the customer adds the pack flagged `raisesLimits`, so one pack
// lifts every limit at once instead of charging per dimension.
model SystemLimit {
  id            String  @id @default(cuid())
  systemId      String
  key           String // services | staff | products
  label         String // "Active services"
  unitLabel     String // "services"
  baseValue     Int
  upgradedValue Int
  helpText      String?

  order  Int     @default(0)
  active Boolean @default(true)

  system CoreSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, key])
  @@index([systemId, order])
}

// A flat-priced bundle of related capability. Packs exist so related tools are
// never sold as separate overlapping line items.
model FeaturePack {
  id          String @id @default(cuid())
  key         String @unique
  name        String
  blurb       String // one sentence, shown on the card
  description String // full explanation, shown when expanded

  price Decimal @default(5) @db.Decimal(12, 2)
  icon  String?

  // Eligibility. A pack always needs at least one core system; `requiresSystems`
  // names the systems it CANNOT work without (e.g. Inventory needs store).
  requiresSystems   String[] @default([])
  compatibleSystems String[] @default([]) // empty = every system
  requiresReason    String? // "...because it manages product orders and deliveries."

  // The pack that lifts every SystemLimit to its upgradedValue.
  raisesLimits Boolean @default(false)

  recommendedFor String[] @default([]) // BusinessType keys
  order          Int      @default(0)
  active         Boolean  @default(true)

  features PackFeature[]
}

model PackFeature {
  id     String  @id @default(cuid())
  packId String
  label  String
  group  String?
  order  Int     @default(0)
  active Boolean @default(true)

  pack FeaturePack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@index([packId, order])
}

// Setup, design and data work. Charged once, never part of the monthly total.
model OneTimeService {
  id            String   @id @default(cuid())
  key           String   @unique
  name          String
  description   String?
  category      String   @default("setup") // website | content | data | custom
  startingPrice Decimal? @db.Decimal(12, 2) // null when quotation-only
  isQuote       Boolean  @default(false) // true = "Requires quotation", never a price
  order         Int      @default(0)
  active        Boolean  @default(true)
}

// Paid to somebody else. Shown so the customer can see it, never added to any
// IGNIS total.
model ExternalCost {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String?
  provider    String?
  costType    String  @default("usage") // fixed | estimated | usage
  order       Int     @default(0)
  active      Boolean @default(true)
}

// Rows of the starting-website comparison. Free text per column so a cell can
// say "Requires E-commerce" or "Display only" rather than a misleading tick.
model ComparisonRow {
  label         String
  id            String  @id @default(cuid())
  informational String
  booking       String
  store         String
  both          String
  note          String?
  order         Int     @default(0)
  active        Boolean @default(true)
}

// A worked example ("Salon website - $35/month"). Labelled as an example, never
// as a plan, and its total is DERIVED from the systems and packs it names.
model RecommendedSetup {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  systemKeys  String[] @default([])
  packKeys    String[] @default([])
  icon        String?
  order       Int      @default(0)
  active      Boolean  @default(true)
}

model PricingFaq {
  id       String  @id @default(cuid())
  question String
  answer   String
  order    Int     @default(0)
  active   Boolean @default(true)
}

// Pricing terms and the glossary tooltips.
model PricingTerm {
  id     String  @id @default(cuid())
  kind   String  @default("term") // term | glossary
  title  String? // glossary word, e.g. "Small update"
  body   String
  order  Int     @default(0)
  active Boolean @default(true)

  @@index([kind, order])
}

// Editable copy: page headings, the maximum-price wording, the WhatsApp
// template. Keyed so the apps ask for a key and never hold the sentence.
model PricingContent {
  id     String  @id @default(cuid())
  key    String  @unique // pricing.heading | builder.maxNote | whatsapp.template
  label  String // what this is, for the admin screen
  value  String
  active Boolean @default(true)
}

model BusinessType {
  id                 String   @id @default(cuid())
  key                String   @unique
  name               String
  icon               String?
  recommendedSystems String[] @default([])
  priorityPacks      String[] @default([])
  order              Int      @default(0)
  active             Boolean  @default(true)
}

// A configuration submitted from the Plan Builder. Snapshots what the customer
// was shown so a later price change never rewrites their request.
model PlanConfiguration {
  id     String @id @default(cuid())
  code   String @unique // CFG-202607-001
  status String @default("New") // New | Contacted | Quoted | Converted | Closed

  contactName  String?
  businessName String?
  phone        String?
  email        String?
  businessType String?
  notes        String?

  // What the customer chose. systemKeys/packKeys are the live model; planKey and
  // coreSystem are kept nullable so configurations submitted under the old
  // plan model stay readable exactly as they were sent.
  systemKeys   String[] @default([]) // booking | store
  packKeys     String[] @default([])
  oneTimeKeys  String[] @default([])
  externalKeys String[] @default([])

  planKey        String?
  coreSystem     String?
  capacities     Json?
  selectedAddOns Json? // [{ key, name, price }] — snapshot of the packs/systems charged
  quoteItems     Json? // [{ key, name }]

  monthlyTotal Decimal @default(0) @db.Decimal(12, 2)
  oneTimeTotal Decimal @default(0) @db.Decimal(12, 2)
  breakdown    Json? // full engine output as shown to the customer

  salespersonId String?
  leadId        String? @unique
  source        String  @default("Plan Builder")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archived  Boolean  @default(false)

  @@index([status])
}
